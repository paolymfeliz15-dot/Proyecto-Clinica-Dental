@model List<AuraDental.Data.Entities.Servicio>

@{
    ViewData["Title"] = "Gestionar Servicios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestionar Servicios</h2>
        <a asp-action="Crear" class="btn btn-primary">+ Nuevo</a>
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Duración</th>
                <th>Precio</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var servicio in Model)
            {
                <tr>
                    <td>@servicio.Nombre</td>
                    <td>@servicio.DuracionMinutos min</td>
                    <td>@servicio.Precio.ToString("C")</td>
                    <td>
                        @if (servicio.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@servicio.ServicioId" class="btn btn-sm btn-outline-info">Ver</a>
                        <a asp-action="Editar" asp-route-id="@servicio.ServicioId" class="btn btn-sm btn-outline-primary">Editar</a>

                        <form asp-action="CambiarEstado" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@servicio.ServicioId" />
                            <input type="hidden" name="activo" value="@(!servicio.Activo)" />
                            @if (servicio.Activo)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success">Activar</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="AdministradorDashboard" asp-action="Index" class="btn btn-link">← Volver al panel</a>
</div>