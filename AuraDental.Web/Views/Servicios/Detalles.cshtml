@model AuraDental.Data.Entities.Servicio

@{
    ViewData["Title"] = "Detalles del Servicio";
}

<div class="container mt-4" style="max-width: 500px;">
    <h2>Detalles</h2>

    <dl class="row">
        <dt class="col-sm-4">Nombre</dt>
        <dd class="col-sm-8">@Model.Nombre</dd>

        <dt class="col-sm-4">Descripción</dt>
        <dd class="col-sm-8">@Model.Descripcion</dd>

        <dt class="col-sm-4">Duración</dt>
        <dd class="col-sm-8">@Model.DuracionMinutos minutos</dd>

        <dt class="col-sm-4">Precio</dt>
        <dd class="col-sm-8">@Model.Precio.ToString("C")</dd>

        <dt class="col-sm-4">Estado</dt>
        <dd class="col-sm-8">@(Model.Activo ? "Activo" : "Inactivo")</dd>
    </dl>

    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>