<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuraDental</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/aura-theme.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark aura-navbar mb-4">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2C8.5 2 6 4.2 6 7.5c0 2.3.7 3.6 1.2 5.5.4 1.6.6 4.3 1.3 6.8.3 1.1.9 1.7 1.6 1.7.9 0 1.2-1 1.4-2.3.2-1.4.3-3.2 1.5-3.2s1.3 1.8 1.5 3.2c.2 1.3.5 2.3 1.4 2.3.7 0 1.3-.6 1.6-1.7.7-2.5.9-5.2 1.3-6.8.5-1.9 1.2-3.2 1.2-5.5C18 4.2 15.5 2 12 2Z" fill="white" />
                    </svg>
                    AuraDental
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var rolActual = Context.Session.GetString("Rol");
                        }
                        @if (rolActual == "Administrador")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="AdministradorDashboard" asp-action="Index">Panel</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Personal" asp-action="Index">Personal</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Servicios" asp-action="Index">Servicios</a></li>
                        }
                        else if (rolActual == "Asistente")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="AsistenteDashboard" asp-action="Index">Panel</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Agenda" asp-action="Index">Agenda</a></li>
                        }
                        else if (rolActual == "Paciente")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="PacienteDashboard" asp-action="Index">Panel</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Disponibilidad" asp-action="Index">Disponibilidad</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="Index">Mis Citas</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (rolActual != null)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Cuenta" asp-action="EditarPerfil">Mi Perfil</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Cuenta" asp-action="Logout">Cerrar sesión</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Cuenta" asp-action="Login">Iniciar sesión</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="aura-footer">
        <div class="container d-flex justify-content-between flex-wrap">
            <span>&copy; 2026 AuraDental — Sistema de Gestión Clínica Dental</span>
            <span>Proyecto Integrador de Conocimientos II</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>