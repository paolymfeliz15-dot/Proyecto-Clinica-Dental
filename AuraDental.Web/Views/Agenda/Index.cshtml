@model List<AuraDental.Data.Entities.BloqueAgenda>

@{
    ViewData["Title"] = "Gestionar Agenda";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gestionar Agenda</h2>
        <a asp-action="Crear" class="btn btn-primary">+ Nuevo Bloque</a>
    </div>

    <table class="table table-hover">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Hora inicio</th>
                <th>Hora fin</th>
                <th>Estado</th>
                <th>Creado por</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bloque in Model)
            {
                <tr>
                    <td>@bloque.Fecha.ToString("dd/MM/yyyy")</td>
                    <td>@bloque.HoraInicio.ToString(@"hh\:mm")</td>
                    <td>@bloque.HoraFin.ToString(@"hh\:mm")</td>
                    <td>
                        @if (bloque.Disponible)
                        {
                            <span class="badge bg-success">Disponible</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Ocupado</span>
                        }
                    </td>
                    <td>@bloque.Usuario.NombreCompleto</td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@bloque.BloqueAgendaId" class="btn btn-sm btn-outline-info">Ver</a>
                        <a asp-action="Editar" asp-route-id="@bloque.BloqueAgendaId" class="btn btn-sm btn-outline-primary">Editar</a>

                        <form asp-action="Eliminar" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este bloque de agenda?');">
                            <input type="hidden" name="id" value="@bloque.BloqueAgendaId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="AsistenteDashboard" asp-action="Index" class="btn btn-link">← Volver al panel</a>
</div>