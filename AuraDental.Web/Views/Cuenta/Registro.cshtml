@{
    ViewData["Title"] = "Registro";
}

<div class="container mt-5" style="max-width: 400px;">
    <h2 class="text-center mb-4">AuraDental</h2>
    <h4 class="text-center mb-4">Crear Cuenta</h4>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Registro">
        <div class="mb-3">
            <label class="form-label">Nombre completo</label>
            <input type="text" name="nombreCompleto" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Correo electrónico</label>
            <input type="email" name="email" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" name="password" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Rol</label>
            <select name="rolId" class="form-select" required>
                @foreach (var rol in ViewBag.Roles)
                {
                    <option value="@rol.RolId">@rol.Nombre</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-success w-100">Registrarme</button>
    </form>

    <p class="text-center mt-3">
        ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión aquí</a>
    </p>
</div>