@{
    ViewData["Title"] = "Panel de Asistente";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Bienvenido/a, @ViewBag.NombreCompleto</h2>
        <a asp-controller="Cuenta" asp-action="Logout" class="btn btn-outline-danger">Cerrar sesión</a>
    </div>

    <h5 class="text-muted mb-3">Panel de Asistente</h5>

    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="Agenda" asp-action="Index" class="text-decoration-none">
                <div class="card p-3">
                    <h5>Gestionar Agenda</h5>
                    <p class="text-muted mb-0">Bloques de horario disponibles</p>
                </div>
            </a>
        </div>
    </div>

    <p class="text-muted mt-4">Registrar Expedientes llegará en el Sprint 4.</p>
</div>